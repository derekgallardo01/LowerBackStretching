rules_version = '2';

// Lower Back Stretching — Firestore security rules.
//
// Two principles:
//   1. A signed-in user (anonymous or upgraded) can read and write
//      their own documents under /users/{uid}/**. Nobody else can
//      touch them.
//   2. Buddy rooms (workout-buddy mode, future) live under
//      /buddyRooms/{roomId} and require both participants to be
//      listed in the doc's `participants` array to read or update.
//
// Anyone not authenticated gets nothing. The mobile clients
// authenticate anonymously on first launch (see Sync module).

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Per-user data -----

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Sessions: client-written records of completed routines.
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Custom routines: client-written / synced down on other devices.
      match /routines/{routineId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Program-progress bookmarks (per-program currentDay).
      match /programProgress/{programId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Flexibility self-test measurements.
      match /flexibilityTests/{testId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ----- Buddy rooms (future) -----
    //
    // A buddy room is a shared session both participants watch in
    // real time. Participants is an array of UIDs declared at create
    // time; only those UIDs can read/update.

    match /buddyRooms/{roomId} {
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }

    // Anything else: denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
